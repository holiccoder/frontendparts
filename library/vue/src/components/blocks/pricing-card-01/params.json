{
    "plan": {
        "type": "string",
        "default": "Starter",
        "description": "Plan name."
    },
    "price": {
        "type": "number",
        "default": 9,
        "description": "Price amount (number only; pair with `currency`)."
    },
    "currency": {
        "type": "string",
        "default": "$",
        "description": "Currency symbol shown before the price."
    },
    "period": {
        "type": "string",
        "default": "/mo",
        "description": "Billing period label shown after the price."
    },
    "description": {
        "type": "text",
        "default": "",
        "description": "Short plan summary. Hidden when empty."
    },
    "features": {
        "type": "array",
        "default": [],
        "description": "Included features; each item is a string shown as a list row."
    },
    "ctaLabel": {
        "type": "string",
        "default": "Choose plan",
        "description": "Call-to-action button label."
    },
    "ctaHref": {
        "type": "url",
        "default": "#",
        "description": "Call-to-action link target."
    },
    "featured": {
        "type": "boolean",
        "default": false,
        "description": "Highlight this card as the recommended plan."
    },
    "badgeLabel": {
        "type": "string",
        "default": "",
        "description": "Badge text on the featured card. Hidden when empty."
    }
}
