{
    "label": {
        "type": "string",
        "default": "Get started",
        "description": "Visible button text."
    },
    "href": {
        "type": "url",
        "default": "#",
        "description": "Link target."
    },
    "variant": {
        "type": "enum",
        "options": ["primary", "secondary", "ghost", "inverted", "invertedGhost"],
        "default": "primary",
        "description": "Visual style (`inverted*` variants are for accent/dark backgrounds)."
    },
    "size": {
        "type": "enum",
        "options": ["sm", "md", "lg"],
        "default": "md",
        "description": "Size preset."
    },
    "showArrow": {
        "type": "boolean",
        "default": false,
        "description": "Show a trailing arrow icon."
    }
}
